<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF005BBF"
                android:centerColor="#FF1A73E8"
                android:endColor="#FFD8E2FF"
                android:angle="270" />
        </shape>
    </item>

    <!-- Removed launcher bitmap to avoid showing old branded image.
         To add a custom photo for the native launch, put a PNG at
         android/app/src/main/res/drawable/launch_image.png and add a
         <item> with a bitmap referencing @drawable/launch_image here. -->
</layer-list>
